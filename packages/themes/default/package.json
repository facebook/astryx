{
  "name": "@xds/theme-default",
  "version": "0.0.11",
  "private": false,
  "description": "Default theme for XDS components (Heroicons)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/default.js",
  "types": "./dist/default.d.ts",
  "exports": {
    ".": {
      "types": "./dist/default.d.ts",
      "import": "./dist/default.js",
      "require": "./dist/default.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/defaultTheme.ts -o dist/theme.css && tsup"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  },
  "module": "./dist/default.js"
}
