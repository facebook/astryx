{
  "name": "@xds/theme-brutalist",
  "version": "0.0.11",
  "private": true,
  "description": "Brutalist theme for XDS \u2014 zero radius, monospace, heavy borders",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/brutalist.js",
  "module": "./dist/brutalist.js",
  "types": "./dist/brutalist.d.ts",
  "exports": {
    ".": {
      "types": "./dist/brutalist.d.ts",
      "import": "./dist/brutalist.js",
      "require": "./dist/brutalist.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/brutalistTheme.ts -o dist/theme.css && tsup"
  },
  "peerDependencies": {
    "@xds/core": "*"
  },
  "devDependencies": {
    "@xds/cli": "*"
  }
}
