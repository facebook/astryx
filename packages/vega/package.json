{
  "name": "@xds/vega",
  "version": "0.0.1",
  "description": "XDS Vega wrapper — chart and data visualization components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vega-lite": ">=5.0.0",
    "vega-embed": ">=6.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
