{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "strict": true
  },
  "include": [
    "api/**/*.mjs",
    "api/**/*.ts",
    "cli/**/*.mjs",
    "cli/**/*.ts",
    "codemods/**/*.mjs",
    "codemods/**/*.ts",
    "lib/**/*.mjs",
    "lib/**/*.ts",
    "utils/**/*.mjs",
    "utils/**/*.ts",
    "types/**/*.ts",
    "schemas/**/*.mjs",
    "schemas/**/*.ts",
    "authoring/**/*.mjs",
    "authoring/**/*.ts",
    "bin/**/*.mjs",
    "scripts/**/*.mjs",
    "docs/**/*.mjs",
    "templates/**/*.mjs",
    "templates/**/*.ts",
    "templates/**/*.tsx"
  ],
  "exclude": ["**/*.test.mjs"]
}
