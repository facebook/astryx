{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "strict": true
  },
  "include": [
    "src/**/*.mjs",
    "src/**/*.ts",
    "bin/**/*.mjs",
    "scripts/**/*.mjs",
    "docs/**/*.mjs",
    "templates/**/*.mjs",
    "templates/**/*.ts",
    "templates/**/*.tsx"
  ],
  "exclude": ["src/**/*.test.mjs"]
}
