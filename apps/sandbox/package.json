{
  "name": "@xds/sandbox",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:deps": "pnpm -F @xds/theme-default build && pnpm -F @xds/theme-neutral build && pnpm -F @xds/theme-brutalist build && pnpm -F @xds/theme-matcha build && pnpm -F @xds/theme-daily build && pnpm -F @xds/theme-stone build && pnpm -F @xds/theme-gothic build && pnpm -F @xds/theme-chocolate build && pnpm -F @xds/theme-y2k build && pnpm -F @xds/theme-butter build",
    "generate:versions": "node scripts/generate-versions.js",
    "generate:changelog": "node scripts/generate-changelog.js",
    "generate:cli": "node scripts/generate-cli-registry.mjs",
    "generate": "node ../../scripts/sync-templates.js && pnpm generate:versions && pnpm generate:changelog && pnpm generate:cli && node scripts/generate-foundation-docs.mjs",
    "dev": "pnpm generate && (node ../../scripts/sync-templates.js --watch & next dev)",
    "build": "pnpm generate && next build",
    "start": "next start",
    "postinstall": "xds agent-docs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@stylexjs/stylex": "^0.18.3",
    "@xds/cli": "*",
    "@xds/core": "*",
    "@xds/lab": "*",
    "@xds/theme-default": "*",
    "@xds/theme-neutral": "*",
    "@xds/theme-brutalist": "*",
    "@xds/theme-matcha": "*",
    "@xds/theme-daily": "*",
    "next": "^15.5.16",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^2.15.3",
    "@xds/theme-stone": "*",
    "@xds/theme-gothic": "*",
    "@xds/theme-chocolate": "*",
    "@xds/theme-y2k": "*",
    "@xds/theme-butter": "*"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@stylexjs/babel-plugin": "^0.18.3",
    "@stylexjs/postcss-plugin": "^0.18.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "commander": "^12.1.0",
    "typescript": "^6.0.3",
    "@xds/build": "*"
  }
}