{
  "name": "@xds/sandbox",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:deps": "yarn workspace @xds/core build && yarn workspace @xds/theme-default build && yarn workspace @xds/theme-neutral build && yarn workspace @xds/theme-brutalist build && yarn workspace @xds/theme-meta build && yarn workspace @xds/theme-whatsapp build && yarn workspace @xds/theme-daily build",
    "generate:versions": "node scripts/generate-versions.js",
    "predev": "node ../../scripts/sync-templates.js && yarn generate:versions",
    "dev": "node ../../scripts/sync-templates.js --watch & vite",
    "prebuild": "node ../../scripts/sync-templates.js && yarn generate:versions",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "postinstall": "xds agent-docs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@stylexjs/stylex": "^0.18.2",
    "@xds/cli": "*",
    "@xds/core": "*",
    "@xds/lab": "*",
    "@xds/theme-brutalist": "*",
    "@xds/theme-daily": "*",
    "@xds/theme-default": "*",
    "@xds/theme-meta": "*",
    "@xds/theme-neutral": "*",
    "@xds/theme-whatsapp": "*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@stylexjs/unplugin": "^0.18.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
